rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // stores/{storeId}/logo/ 下的所有檔案 — owner 可上傳，所有人可讀
    match /stores/{storeId}/logo/{filename} {
      allow read: if true;
      allow write: if request.auth != null
                   && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.storeId == storeId
                   && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == "owner"
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // 其他路徑全部禁止
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
