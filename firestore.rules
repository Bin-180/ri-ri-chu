rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    // 讀取登入者的 users/{uid} profile（每次規則評估計一次 read）
    function profile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // 登入者的 storeId 必須與路徑中的 storeId 相同
    function isSameStore(storeId) {
      return isAuth() && profile().storeId == storeId;
    }

    // 任何合法店家員工（staff / manager / owner）
    function isStaff(storeId) {
      return isSameStore(storeId) && profile().role in ["staff", "manager", "owner"];
    }

    // manager 或以上
    function isManager(storeId) {
      return isSameStore(storeId) && profile().role in ["manager", "owner"];
    }

    // owner 限定
    function isOwner(storeId) {
      return isSameStore(storeId) && profile().role == "owner";
    }

    // ── 訂單新增驗證 ──────────────────────────────────────────────────────
    // 前台允許送出的欄位白名單（phone / scheduledTime 為選填）
    function isValidNewOrder() {
      let d    = request.resource.data;
      let allowed = [
        "orderNumber", "customer", "note", "service", "payment",
        "items", "total", "status", "createdAt", "phone", "scheduledTime"
      ];
      return d.status == "pending"
          && d.service in ["內用", "外帶"]
          && d.total is number && d.total > 0
          && d.items is list
          && d.items.size() > 0
          && d.items.size() <= 50
          && d.keys().hasOnly(allowed);
    }

    // ── 訂單狀態更新驗證 ──────────────────────────────────────────────────
    // 只允許 pending → done，且只能異動 status 與 doneAt 兩個欄位
    function isValidStatusUpdate() {
      let before = resource.data;
      let after  = request.resource.data;
      return before.status == "pending"
          && after.status  == "done"
          // 異動的欄位集合只能是 status、doneAt
          && after.diff(before).affectedKeys().hasOnly(["status", "doneAt"]);
    }

    // ── users/{uid} ──────────────────────────────────────────────────────
    match /users/{uid} {
      allow read:  if request.auth.uid == uid;
      allow write: if false;
    }

    // ── stores/{storeId} （店家設定文件）────────────────────────────────
    match /stores/{storeId} {
      allow read:  if isStaff(storeId);
      allow write: if isOwner(storeId);
    }

    // ── stores/{storeId}/menu ─────────────────────────────────────────────
    match /stores/{storeId}/menu/{itemId} {
      allow read:  if true;
      allow write: if isOwner(storeId);
    }

    // ── stores/{storeId}/orders ───────────────────────────────────────────
    match /stores/{storeId}/orders/{orderId} {
      // 未登入客人可新增訂單（通過格式驗證）
      allow create: if isValidNewOrder();

      // staff：只能讀 pending 訂單（即時收單用）
      //   - get：單筆讀取，直接檢查 resource.data.status
      //   - list：query 讀取，Firestore Rules 要求 query 本身帶 status=="pending" 過濾條件才通過
      // manager / owner：可讀全部訂單（查歷史、統計）
      allow get:  if isManager(storeId)
                  || (isStaff(storeId) && resource.data.status == "pending");
      allow list: if isManager(storeId)
                  || (isStaff(storeId) && resource.data.status == "pending");

      // pending → done，且只能改 status / doneAt
      allow update: if isManager(storeId) && isValidStatusUpdate();

      // 刪除只有 owner
      allow delete: if isOwner(storeId);
    }
  }
}
