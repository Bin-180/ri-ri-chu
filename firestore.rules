rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function profile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // active 欄位不存在（舊帳號）視為啟用；只有明確 false 才封鎖
    function isActiveUser() {
      return isAuth() &&
          (!profile().keys().hasAny(["active"]) || profile().active != false);
    }

    function isSameStore(storeId) {
      return isActiveUser() && profile().storeId == storeId;
    }

    function isStaff(storeId) {
      return isSameStore(storeId) &&
          (profile().role == "staff" ||
           profile().role == "manager" ||
           profile().role == "owner");
    }

    function isManager(storeId) {
      return isSameStore(storeId) &&
          (profile().role == "manager" || profile().role == "owner");
    }

    function isOwner(storeId) {
      return isSameStore(storeId) && profile().role == "owner";
    }

    function isValidNewOrder() {
      return request.resource.data.status == "pending" &&
          request.resource.data.total is number &&
          request.resource.data.total > 0 &&
          request.resource.data.items is list &&
          request.resource.data.items.size() > 0 &&
          request.resource.data.items.size() <= 50 &&
          request.resource.data.keys().hasOnly([
            "orderNumber", "customer", "note", "service", "payment",
            "items", "total", "status", "createdAt", "phone", "scheduledTime"
          ]);
    }

    function isValidStatusUpdate() {
      return resource.data.status == "pending" &&
          request.resource.data.status == "done" &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status", "doneAt"]);
    }

    match /users/{uid} {
      // 停用帳號仍需能讀自己的 profile（前端才能拿到 active:false 並登出）
      allow read: if request.auth.uid == uid;

      // 啟用中的 owner 可為同店建立 staff / manager 帳號
      allow create: if isOwner(request.resource.data.storeId) &&
          (request.resource.data.role == "staff" ||
           request.resource.data.role == "manager") &&
          request.resource.data.active == true &&
          request.resource.data.keys().hasOnly(
            ["storeId", "role", "displayName", "email", "active", "createdAt"]
          );

      // 啟用中的 owner 可修改同店 staff / manager 的 role 與 active
      allow update: if isOwner(resource.data.storeId) &&
          request.auth.uid != uid &&
          (resource.data.role == "staff" || resource.data.role == "manager") &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(["role", "active"]) &&
          (request.resource.data.role == "staff" ||
           request.resource.data.role == "manager");

      allow delete: if false;
    }

    match /stores/{storeId}/members/{uid} {
      allow read: if isStaff(storeId);

      // owner 建立成員：storeId 鎖路徑、role 只 staff/manager、active 是 bool、keys 白名單
      allow create: if isOwner(storeId) &&
          request.resource.data.storeId == storeId &&
          (request.resource.data.role == "staff" ||
           request.resource.data.role == "manager") &&
          request.resource.data.active is bool &&
          request.resource.data.keys().hasOnly(
            ["storeId", "role", "displayName", "email", "active", "createdAt"]
          );

      // owner 只能改 role / active；前後 storeId 鎖路徑；前後 role 只 staff/manager
      allow update: if isOwner(storeId) &&
          resource.data.storeId == storeId &&
          request.resource.data.storeId == storeId &&
          (resource.data.role == "staff" || resource.data.role == "manager") &&
          (request.resource.data.role == "staff" ||
           request.resource.data.role == "manager") &&
          request.resource.data.active is bool &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(["role", "active"]);

      allow delete: if isOwner(storeId);
    }

    match /stores/{storeId} {
      allow get:    if true;
      allow list:   if false;
      allow create: if isOwner(storeId);
      allow delete: if isOwner(storeId);
      // owner: full update; manager: only acceptingOrders / pauseMessage
      allow update: if isOwner(storeId) ||
          (isManager(storeId) &&
           request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(["acceptingOrders", "pauseMessage"]));
    }

    match /stores/{storeId}/private/{doc} {
      allow read:  if isOwner(storeId);
      allow write: if isOwner(storeId);
    }

    match /stores/{storeId}/menu/{itemId} {
      allow read:  if true;
      allow write: if isOwner(storeId);
    }

    match /stores/{storeId}/orders/{orderId} {
      allow create: if isValidNewOrder();
      allow read:   if isManager(storeId);
      allow update: if isManager(storeId) && isValidStatusUpdate();
      allow delete: if isOwner(storeId);
    }

    match /stores/{storeId}/pendingOrders/{orderId} {
      allow create: if isValidNewOrder();
      allow read:   if isStaff(storeId);
      allow update: if false;
      allow delete: if isManager(storeId);
    }
  }
}
